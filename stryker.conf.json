{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing configuration",
  "packageManager": "npm",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/index.ts",
    "!src/shared/authServer.ts",
    "!src/meta/mcpdescription.ts"
  ],
  "testRunner": "command",
  "commandRunner": {
    "command": "npm run test"
  },
  "coverageAnalysis": "perTest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation.html"
  },
  "thresholds": {
    "high": 90,
    "low": 70,
    "break": 60
  },
  "mutator": {
    "plugins": null,
    "excludedMutations": []
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "reports",
    "test"
  ]
}
