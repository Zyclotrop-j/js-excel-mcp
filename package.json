{
  "name": "js-excel-mcp",
  "version": "1.0.0",
  "description": "JavaScript-based Excel MCP server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 delete js-excel-mcp",
    "pm2:restart": "pm2 restart js-excel-mcp",
    "pm2:logs": "pm2 logs js-excel-mcp --lines 20 --nostream",
    "pm2:status": "pm2 list",
    "test": "tsx test/run.ts",
    "test:unit": "tsx test/run.ts",
    "test:integration": "tsx test/run-integration.ts",
    "test:e2e": "tsx test/run-e2e.ts",
    "test:property": "tsx test/run-property.ts",
    "test:mutation": "npx stryker run",
    "coverage": "npx c8 tsx test/run.ts"
  },
  "keywords": [
    "mcp",
    "excel",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/express": "^2.0.0-beta.2",
    "@modelcontextprotocol/node": "^2.0.0-beta.3",
    "@modelcontextprotocol/server": "^2.0.0-beta.3",
    "@office-kit/xlsx": "^0.8.0",
    "@toon-format/toon": "^2.3.0",
    "better-auth": "^1.6.11",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lru-cache": "^11.5.0",
    "wretch": "^3.0.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260718.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "baretest": "^2.0.0",
    "c8": "^10.1.3",
    "fast-check": "^4.9.0",
    "pm2": "^7.0.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.110.0"
  }
}
